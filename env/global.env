# Global runtime config shared by ALL images.
# Baked into each image and sourced by scripts/startup/entrypoint.sh as
# DEFAULTS. Any value already present in the container/Kasm session
# environment WINS over the value here (real env overrides these defaults).
#
# Format: KEY="value"  (sourced by bash, not docker --env-file).
# Comments and blank lines are ignored.

# --- DNS ---
# Space-separated nameserver IPs. Empty = keep runtime-provided resolv.conf.
DNS_SERVERS=""
# Space-separated search domains.
DNS_SEARCH=""

# --- Locale / time ---
TZ="UTC"
