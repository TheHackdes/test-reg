# Global runtime config shared by ALL images.
# Baked into each image and sourced by scripts/startup/entrypoint.sh as
# DEFAULTS. Any value already present in the container/Kasm session
# environment WINS over the value here (real env overrides these defaults).
#
# Format: KEY="value"  (sourced by bash, not docker --env-file).
# Comments and blank lines are ignored.

# --- DNS ---
# Space-separated nameserver IPs. Empty = keep runtime-provided resolv.conf.
DNS_SERVERS=""
# Space-separated search domains.
DNS_SEARCH=""

# --- Locale / time ---
TZ="UTC"

# --- LDAP / SSSD identity ---
# Rendered into /etc/sssd/sssd.conf by scripts/startup/entrypoint.sh at boot.
# These are the GLOBAL knobs for LDAP auth; real env still overrides them.
#
# Master switch. "true" starts sssd and resolves users from LDAP; anything
# else keeps the image on local accounts only (kasm-user fallback).
LDAP_ENABLED="false"
# LDAP/LDAPS server URI. Plain ldap:// = no encryption (sssd then needs the
# disable-tls flag, set automatically by the entrypoint). ldaps:// recommended
# for production. e.g. ldap://ldap.example.com
LDAP_URI="ldap://ldap.example.com"
# Base DN for searches. e.g. dc=example,dc=com
LDAP_SEARCH_BASE="dc=example,dc=com"
# Schema: rfc2307 (OpenLDAP posix), rfc2307bis, or ad (Active Directory).
LDAP_SCHEMA="rfc2307"
# Service-account bind. Leave empty for anonymous bind.
LDAP_DEFAULT_BIND_DN=""
LDAP_DEFAULT_AUTHTOK=""
# TLS. reqcert: demand | allow | never. cacert: path to the CA bundle.
# Empty cacert = omitted. With plain ldap:// (no TLS) these are unused.
LDAP_TLS_REQCERT="never"
LDAP_TLS_CACERT=""
# StartTLS on a plain ldap:// connection ("true"/"false"). Ignored for ldaps://.
LDAP_ID_USE_START_TLS="false"
# Optional overrides; empty = derive from LDAP_SEARCH_BASE.
LDAP_USER_SEARCH_BASE=""
LDAP_GROUP_SEARCH_BASE=""
# Optional LDAP filter that gates who may log in (sets access_provider=ldap).
# e.g. (memberOf=cn=kasm,ou=groups,dc=example,dc=com)
LDAP_ACCESS_FILTER=""
# Home-dir template (%u = username) and login shell forced for LDAP users.
LDAP_HOME_DIR_TEMPLATE="/home/%u"
LDAP_DEFAULT_SHELL="/bin/bash"

# --- Session user ---
# The authenticated username for THIS session. Kasm Workspaces (which performs
# the LDAP login at the portal) injects it per container. The entrypoint runs
# the whole XFCE desktop as this user and provisions their home dir.
# Empty -> falls back to the local kasm-user account.
KASM_USER=""
